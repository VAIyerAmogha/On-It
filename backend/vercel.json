{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "lib/__init__.py",
          "lib/*.py",
          "routers/__init__.py",
          "routers/*.py",
          "models/__init__.py",
          "models/*.py",
          "main.py",
          "config.py",
          "db.py"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}